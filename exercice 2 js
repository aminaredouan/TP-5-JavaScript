let nombreSecret = Math.floor(Math.random() * 10) + 1;
let tentative = 0;
let proposition;

do {
     proposition = parseInt(prompt("Devinez un nombre entre 1 et 10 :"));
     tentative++;
     
     if (proposition < nombreSecret) {
     alert("Le nombre est plus grand !");
     } else if (proposition > nombreSecret) {
     alert("Le nombre est plus petit !");
     }
     
} while (proposition !== nombreSecret);

alert("Bravo ! Trouve en " + tentative + " tentatives.");

let nombre1 = parseFloat(prompt("Veuillez saisir le premier nombre"));
let nombre2 = parseFloat(prompt("Veuillez saisir le deuxième nombre"));

if (isNaN(nombre1) || isNaN(nombre2)) {
     console.log("Erreur: veuillez entrer des nombres valides");
}
else {
     let somme = nombre1 + nombre2;
     let difference = nombre1 - nombre2;
     let produit = nombre1 * nombre2;
     let division = nombre1 / nombre2;

     if (nombre2 !== 0) {
            division = nombre1 / nombre2;
     }
     else {
           division = "Impossible (division par 0)";
     }
     
     console.log("Somme:", somme);
     console.log("Différence :", difference);
     console.log("Produit:", produit);
     console.log("Division:", division);
}
